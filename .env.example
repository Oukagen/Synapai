# Automation API Configuration
# Copy this file to .env.local and fill in your values

# LLM Provider (openai, zhipu, deepseek, kimi, qwen, wenxin, custom)
AUTOMATION_LLM_PROVIDER=deepseek
AUTOMATION_LLM_API_KEY=your-api-key-here
AUTOMATION_LLM_ENDPOINT=https://api.deepseek.com/v1
AUTOMATION_LLM_MODEL=deepseek-chat

# Default cover image (optional)
AUTOMATION_DEFAULT_COVER_IMAGE=
